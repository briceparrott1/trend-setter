# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Google AI Studio (Gemini) — get at aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-001

# Kling AI — get at kling.ai/dev
KLING_API_KEY=

# Kling AI style (optional overrides)
# KLING_STYLE_PREFIX=Cinematic photorealistic documentary footage, 4K, professional lighting, high production value:
# KLING_NEGATIVE_PROMPT=cartoon, anime, illustration, CGI, 3D animation, sketch, painting, watercolor, low quality, blurry, distorted

# OpenAI — platform.openai.com (used for TTS voiceover generation)
OPENAI_API_KEY=

# Video output directory (relative to project root)
VIDEO_OUTPUT_DIR=output

# Perplexity Sonar API — get at perplexity.ai/api
PERPLEXITY_API_KEY=

# YouTube Data API v3 — enable at console.cloud.google.com
YOUTUBE_API_KEY=

# NewsData.io — get at newsdata.io (free tier works in cloud production)
NEWSDATAIO_API_KEY=

# Google Trends — no key needed
GOOGLE_TRENDS_GEO=US

# Pipeline config
TREND_CATEGORIES=education,science,technology,history
POST_INTERVAL_HOURS=6
MAX_TRENDS_TO_FETCH=10

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Google Cloud / Vertex AI (Gemini + Veo 2)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-001
VEO_MODEL=veo-002
# Path to the service account JSON key used for Vertex AI auth.
GOOGLE_APPLICATION_CREDENTIALS=

# YouTube Data API v3
YOUTUBE_API_KEY=

# TikTok Research API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Trends (pytrends) - no API key required
GOOGLE_TRENDS_GEO=US

# Pipeline behavior
TREND_CATEGORIES=entertainment,technology,lifestyle
POST_INTERVAL_HOURS=6
MAX_TRENDS_TO_FETCH=10
